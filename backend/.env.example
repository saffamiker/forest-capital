ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_gemini_key_here
FRONTEND_URL=http://localhost:5173
# Public URL quoted in the welcome email sent on user creation.
# Optional — defaults to FRONTEND_URL; set only if the two diverge.
PLATFORM_URL=https://forest-capital.vercel.app
ENVIRONMENT=development
LOG_LEVEL=INFO
DAILY_CREDIT_CAP_USD=5.00

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED. PostgreSQL connection string (asyncpg driver). The code default is
# a non-secret local placeholder — set the real URL here; never commit a real
# credential. On Render this is provided by the managed Postgres add-on.
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/forestcapital

# ── External data (FRED) ──────────────────────────────────────────────────────
# FRED API key — used by the data pipeline to fetch VIX and DGS2.
FRED_API_KEY=your_fred_key_here

# ── Grok / xAI (Contrarian Analyst + Explainer) ───────────────────────────────
# XAI_API_KEY: a direct xAI key (xai-...) or an OpenRouter key (sk-or-...) —
# auto-detected. If unset, the council runs with Gemini as the sole dissenter
# and the Explainer falls back to Haiku.
XAI_API_KEY=your_xai_or_openrouter_key_here
# Optional operator overrides — leave unset to use the auto-detected defaults.
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4.3

# Magic link authentication
# Authorised users — no other email addresses will ever receive a link
ALLOWED_EMAILS=ruurdsm@queens.edu,thaob@queens.edu,murdockm@queens.edu,panttserk@queens.edu
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@queens.edu
MAGIC_LINK_EXPIRY_MINUTES=15
SESSION_EXPIRY_HOURS=8

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_long_random_string_here

# Developer-only access key (Michael)
MASTER_API_KEY=michael_dev_key_here

# ── Team Activity — GitHub commit ingestion ───────────────────────────────────
# Repository the commit sync + push webhook target.
GITHUB_REPO=saffamiker/forest-capital
# Personal access token (repo scope) — required by /api/v1/activity/commits/sync
# because the repository is private. Without it the sync returns a clear
# "token required" message instead of failing.
GITHUB_TOKEN=your_github_pat_here
# Shared secret validating GitHub push-webhook signatures. REQUIRED on Render
# before the webhook endpoint will accept any event.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=generate_a_long_random_string_here
